    "@tanstack/react-virtual": "^3.13.23",
    "better-auth": "^1.5.6",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@mangostudio/api": "workspace:*",
    "@tailwindcss/vite": "^4.1.14",
