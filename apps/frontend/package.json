{
  "name": "@mangostudio/frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0 && tsc --noEmit",
    "format": "prettier --write 'src/**/*.{ts,tsx,json}'",
