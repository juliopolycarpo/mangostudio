{
  "name": "@mangostudio/shared",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "lint": "eslint src tests --max-warnings 0",
    "lint:fix": "eslint src tests --fix --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "fix": "bun run lint:fix && bun run format",
    "fix:check": "bun run lint && bun run format:check",
    "format": "prettier --ignore-path ../../.prettierignore --write 'src/**/*.{ts,json}'",
    "format:check": "prettier --ignore-path ../../.prettierignore --check 'src/**/*.{ts,json}'",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit"
  },
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/index.ts",
    "./contracts": "./src/contracts/index.ts",
    "./test-utils": "./src/test-utils/index.ts",
    "./i18n": "./src/i18n/index.ts",
    "./utils/model-detection": "./src/utils/model-detection.ts"
  },
  "devDependencies": {
    "typescript": "~5.8.2"
  }
}
