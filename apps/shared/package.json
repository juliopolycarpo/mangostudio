{
  "name": "@mangostudio/shared",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "check": "eslint src tests --max-warnings 0 && prettier --ignore-path ../../.prettierignore --check 'src/**/*.{ts,json}' 'tests/**/*.ts' && tsc --noEmit",
    "fix": "eslint src tests --fix --max-warnings 0 && prettier --ignore-path ../../.prettierignore --write 'src/**/*.{ts,json}' 'tests/**/*.ts'",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit"
  },
  "exports": {
    ".": "./src/index.ts",
    "./chat": "./src/chat/index.ts",
    "./generation": "./src/generation/index.ts",
    "./connectors": "./src/connectors/index.ts",
    "./catalog": "./src/catalog/index.ts",
    "./streaming": "./src/streaming/index.ts",
    "./auth": "./src/auth/index.ts",
    "./errors": "./src/errors/index.ts",
    "./types": "./src/types/index.ts",
    "./contracts": "./src/contracts/index.ts",
    "./test-utils": "./src/test-utils/index.ts",
    "./i18n": "./src/i18n/index.ts",
    "./utils/model-detection": "./src/utils/model-detection.ts"
  },
  "devDependencies": {
    "typescript": "~5.8.2"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49"
  }
}
