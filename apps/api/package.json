{
  "name": "@mangostudio/api",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/app.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "check": "eslint src tests --max-warnings 23 && prettier --ignore-path ../../.prettierignore --check 'src/**/*.{ts,json}' 'tests/**/*.ts' && tsc --noEmit",
    "fix": "eslint src tests --fix --max-warnings 23 && prettier --ignore-path ../../.prettierignore --write 'src/**/*.{ts,json}' 'tests/**/*.ts'",
    "migrate": "bun run src/db/migrate.ts",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:coverage": "bun test --coverage tests/unit tests/integration"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@elysiajs/static": "^1.4.7",
    "@google/genai": "^1.46.0",
    "@mangostudio/shared": "workspace:*",
    "better-auth": "^1.5.6",
    "elysia": "^1.4.28",
    "file-type": "^21.3.4",
    "kysely": "^0.27.6",
    "kysely-bun-sqlite": "^0.3.2",
    "openai": "^6.33.0",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.34.0",
    "@types/bun": "^1.2.0",
    "typescript": "~5.8.2"
  }
}
