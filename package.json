{
  "name": "@mangostudio/root",
  "private": true,
  "license": "MIT",
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:api": "bun run --filter @mangostudio/api dev",
    "dev:frontend": "bun run --filter @mangostudio/frontend dev",
    "build": "bun run --filter @mangostudio/frontend build",
    "build:binary": "bun run scripts/build.ts",
    "build:binary:prod": "BUILD_TYPE=production bun run scripts/build.ts",
    "build:binary:dev": "BUILD_TYPE=development bun run scripts/build.ts",
    "lint": "bun run --filter '*' lint",
    "test": "bun run test:unit && bun run test:integration",
    "test:all": "bun run test",
    "test:unit": "bun run --filter @mangostudio/api test:unit && bun run --filter @mangostudio/shared test:unit && bun run --filter @mangostudio/frontend test:unit",
    "test:integration": "bun run --filter @mangostudio/api test:integration && bun run --filter @mangostudio/frontend test:integration",
    "test:coverage": "bun run --filter @mangostudio/frontend test:coverage",
    "test:ci": "bun run lint && bun run test && bun run test:coverage",
    "migrate": "bun run --filter @mangostudio/api migrate",
    "clean": "rm -rf apps/*/dist apps/*/coverage out",
    "dist-clean": "bun run clean && rm -rf node_modules apps/*/node_modules bun.lock"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@fast-check/vitest": "^0.3.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.1",
    "@vitest/ui": "^4.1.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "vitest": "^4.1.1"
  }
}
