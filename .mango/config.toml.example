# MangoStudio Configuration
# Copy this file to .mango/config.toml (dev) or ~/.mango/config.toml (build).
#
# Resolution hierarchy (highest priority wins):
# 1. .mango/.env       — overrides matching keys from config.toml
# 2. config.toml       — dev: ./.mango/config.toml | build: ~/.mango/config.toml
# 3. Built-in defaults — hardcoded in the application

[server]
host = "localhost"
port = 3001

[frontend]
host = "localhost"
port = 5173

[database]
# Empty = auto-detect:
#   dev:   ./.mango/database.sqlite
#   build: ~/.mango/database.sqlite
path = ""

[uploads]
# Empty = auto-detect: ./uploads (dev) or <exe_dir>/uploads (build)
dir = ""

[auth]
# Required — minimum 32 characters
secret = "your-secret-key-here-min-32-chars"
# Empty = derived from server host:port
url = ""

# Gemini API key connectors.
# Keys defined here appear automatically in the Settings UI.
# You can enable/disable specific models per connector in the UI.
[gemini_api_keys]
# personal = "AIzaSy..."
# work = "AIzaSy..."

# OpenAI-compatible API key connectors.
# Works with OpenAI, DeepSeek, OpenRouter, and other compatible APIs.
# Base URLs for non-OpenAI services are configured in the Settings UI.
[openai_compatible_api_keys]
# openai = "sk-..."
# deepseek = "sk-..."
# openrouter = "sk-or-..."

# Anthropic API key connectors.
[anthropic_api_keys]
# default = "sk-ant-..."
