# MangoStudio Environment Overrides
# Copy this file to .mango/.env to override config.toml values.
# This file takes highest priority over config.toml for matching keys.
#
# Only the keys listed below are recognized as overrides.
# Secrets (API keys, auth secret) are best placed here instead of config.toml.

# BETTER_AUTH_SECRET=your-secret-key-here-min-32-chars
# BETTER_AUTH_URL=http://localhost:3001

# API_HOST=localhost
# API_PORT=3001
# FRONTEND_PORT=5173

# DATABASE_PATH=
# UPLOADS_DIR=

# Gemini API keys (per-connector or global fallback)
# GEMINI_API_KEY=AIzaSy...
# GEMINI_API_KEY_PERSONAL=AIzaSy...
