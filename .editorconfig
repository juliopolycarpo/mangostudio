# EditorConfig — https://editorconfig.org

root = true

# ─── Defaults (all text files) ─── #
[*]
charset               = utf-8
end_of_line           = lf
indent_style          = space
indent_size           = 2
trim_trailing_whitespace = true
insert_final_newline  = true

# ─── TypeScript / TSX / JavaScript / JSX ─── #
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2

# ─── CSS ─── #
[*.css]
indent_size = 2

# ─── JSON / JSONC ─── #
[*.{json,jsonc}]
indent_size = 2

# ─── Markdown ─── #
[*.{md,mdx}]
# Prettier handles trailing whitespace in markdown; keep it untouched here.
trim_trailing_whitespace = false
indent_size              = 2

# ─── TOML (bunfig.toml, config examples) ─── #
[*.toml]
indent_size = 2

# ─── YAML (GitHub Actions, Playwright) ─── #
[*.{yml,yaml}]
indent_size = 2

# ─── HTML ─── #
[*.html]
indent_size = 2

# ─── Shell scripts ─── #
[*.sh]
indent_size  = 2
indent_style = space

# ─── Bun lockfile (binary-like, leave untouched) ─── #
[bun.lock]
insert_final_newline     = unset
trim_trailing_whitespace = unset

# ─── Playwright config ─── #
[playwright.config.ts]
indent_size = 2
