# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=

# DATABASE_PATH: Optional custom path for the SQLite database file.
DATABASE_PATH=

# API_PORT: Optional API port override. Defaults to 3001.
API_PORT=

# UPLOADS_DIR: Optional custom directory for uploaded/generated images.
UPLOADS_DIR=

# Auth
BETTER_AUTH_SECRET=your-secret-key-here-min-32-chars
BETTER_AUTH_URL=http://localhost:3001
